{
  "rewrites": [
    { "source": "/share/session/:token", "destination": "/share/index.html" },
    { "source": "/share/split/:token", "destination": "/share/index.html" },
    { "source": "/share/:token", "destination": "/share/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
