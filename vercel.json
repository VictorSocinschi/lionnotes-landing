{
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/share/session/:token", "destination": "/share/index.html" },
    { "source": "/share/split/:token", "destination": "/share/index.html" },
    { "source": "/share/:token", "destination": "/share/index.html" },
    { "source": "/share", "destination": "/share/index.html" },
    { "source": "/expenses/:token", "destination": "/expenses/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
